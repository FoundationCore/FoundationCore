# CI profile — pinned to clang-19 (available on Ubuntu 24.04 via apt.llvm.org).
#
# Your local profile (.conan2/profiles/clang) sets compiler.version=22 which
# does not exist yet. Update your local profile to match whatever clang version
# is actually installed (run `clang --version` to check).
#
# This file is intentionally kept separate so local and CI versions can diverge
# during toolchain upgrades without breaking each other.

[settings]
os=Linux
arch=x86_64
build_type=Release
compiler=clang
compiler.version=19
compiler.libcxx=libc++

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
tools.build:compiler_executables={"c": "clang", "cpp": "clang++"}
